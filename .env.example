# Copy to .env and fill in. .env is git-ignored and auto-loaded in dev.
#
# Register an OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# - Add the "Jira" permission with scopes:
#     read:jira-work write:jira-work read:jira-user offline_access
# - Set the callback URL to OAUTH_REDIRECT_URI below.
ATLASSIAN_CLIENT_ID=your-client-id
ATLASSIAN_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Random secret (>= 32 chars) used to encrypt the session cookie.
# Generate: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
